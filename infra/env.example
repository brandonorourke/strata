# Copy this file to .env and update values for your environment
ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/strata
OPENAI_API_KEY="[fill this in]"
# SAM.gov Opportunities API key (non-federal = 10 requests/day). Used by
# apps/ingest/ingest_sam_awards.py. Get one at https://sam.gov account → API keys.
SAM_API_KEY="[fill this in]"
# Resend API key for alert email delivery (apps/ingest/emit_alerts.py)
RESEND_API_KEY="[fill this in]"
